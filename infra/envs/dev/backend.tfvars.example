# Terraform remote state — dev environment
# Copy this file to backend.tfvars and fill in all TODO: values
#
#   cp backend.tfvars.example backend.tfvars
#
# Create the S3 bucket first:
#   aws s3 mb s3://your-state-bucket --region us-east-1
#   aws s3api put-bucket-versioning --bucket your-state-bucket \
#     --versioning-configuration Status=Enabled

bucket         = "TODO: your-terraform-state-bucket"
key            = "radius/dev/terraform.tfstate"
region         = "us-east-1"
dynamodb_table = "radius-terraform-locks"
encrypt        = true
