# Production environment configuration for Radius
# Copy this file to terraform.tfvars and fill in all TODO: values
#
#   cp terraform.tfvars.example terraform.tfvars

environment     = "prod"
aws_region      = "us-east-1"
resource_prefix = "radius"

lambda_s3_bucket = "TODO: your-s3-bucket-name"

lambda_memory = {
  event_normalizer   = 512
  detection_engine   = 2048
  incident_processor = 512
  identity_collector = 512
  score_engine       = 2048
  api_handler        = 512
  remediation_engine = 512
}

lambda_timeout = {
  event_normalizer   = 30
  detection_engine   = 120
  incident_processor = 30
  identity_collector = 30
  score_engine       = 120
  api_handler        = 10
  remediation_engine = 60
}

lambda_concurrency_limit = 0
log_retention_days       = 365

cloudtrail_organization_enabled = false
enable_pitr                     = true

score_engine_schedule = "rate(6 hours)"
remediation_dry_run   = true   # Set to false only after validating remediation rules in alert mode

api_throttle_burst_limit = 200
api_throttle_rate_limit  = 100

cognito_callback_urls = ["https://TODO-your-cloudfront-domain/callback"]
cognito_logout_urls   = ["https://TODO-your-cloudfront-domain/logout"]

github_repo = "TODO: your-org/radius"

frontend_s3_bucket         = "TODO: your-frontend-bucket"
cloudfront_distribution_id = "TODO: your-cloudfront-distribution-id"

email_subscriptions = ["TODO: ops-team@example.com"]
https_subscriptions = []

tags = {
  Project     = "Radius"
  Environment = "prod"
  ManagedBy   = "Terraform"
}
